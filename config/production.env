# AssetWise 生产环境配置
# 请根据实际情况修改这些值

# 应用基础配置
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
NEXT_TELEMETRY_DISABLED=1

# 域名配置
NEXTAUTH_URL=https://assetwise.app
NEXT_PUBLIC_APP_URL=https://assetwise.app

# 数据库配置 (请使用实际的生产数据库URL)
DATABASE_URL=postgresql://username:password@host:5432/assetwise_prod

# Supabase 配置
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 认证配置
NEXTAUTH_SECRET=your-very-long-random-secret-key-at-least-32-characters

# Redis 配置
REDIS_URL=redis://redis-server:6379

# 文件存储配置
NEXT_PUBLIC_STORAGE_BUCKET=assetwise-prod-storage

# 监控配置
ENABLE_MONITORING=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production

# 性能配置
ENABLE_COMPRESSION=true
ENABLE_CACHE=true
CACHE_TTL=3600

# 安全配置
ENABLE_CORS=false
ALLOWED_ORIGINS=https://assetwise.app,https://www.assetwise.app
ENABLE_RATE_LIMITING=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_ACCESS_LOGS=true

# 邮件服务配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@assetwise.app
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=AssetWise <noreply@assetwise.app>

# 第三方服务配置
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
HOTJAR_ID=your-hotjar-id

# 数据备份配置
ENABLE_AUTO_BACKUP=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# 通知配置
SLACK_WEBHOOK=https://hooks.slack.com/services/your/webhook/url
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your/webhook/url

# CDN 配置
CDN_URL=https://cdn.assetwise.app
NEXT_PUBLIC_CDN_URL=https://cdn.assetwise.app

# 分析和统计
ENABLE_ANALYTICS=true
MIXPANEL_TOKEN=your-mixpanel-token

# 特性开关
FEATURE_CRYPTO_TRADING=true
FEATURE_REAL_TIME_UPDATES=true
FEATURE_ADVANCED_CHARTS=true
FEATURE_AI_INSIGHTS=false